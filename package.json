{
  "name": "florin",
  "displayName": "Florin",
  "description": "Portable database connections + query library for VS Code, synced across machines via your account. Passwords stay in the OS keychain.",
  "version": "0.0.1",
  "publisher": "asutoshpanda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/75asu/florin.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "florin",
          "title": "Florin",
          "icon": "media/florin.svg"
        }
      ]
    },
    "views": {
      "florin": [
        {
          "id": "florin.connections",
          "name": "Connections",
          "icon": "media/florin.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "florin.connections",
        "contents": "No database connections yet.\n[Add Connection from URL](command:florin.addConnectionFromUrl)"
      }
    ],
    "commands": [
      {
        "command": "florin.addConnectionFromUrl",
        "title": "Add Connection from URL",
        "category": "Florin",
        "icon": "$(add)"
      },
      {
        "command": "florin.listConnections",
        "title": "List Connections",
        "category": "Florin"
      },
      {
        "command": "florin.refresh",
        "title": "Refresh",
        "category": "Florin",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "florin.addConnectionFromUrl",
          "when": "view == florin.connections",
          "group": "navigation"
        },
        {
          "command": "florin.refresh",
          "when": "view == florin.connections",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package -o florin.vsix",
    "install:local": "npm run package && code --install-extension florin.vsix --force",
    "vscode:prepublish": "npm run compile",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.4.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.1.0",
    "husky": "^9.1.0",
    "typescript": "^5.5.0"
  }
}
