{
  "name": "florin",
  "displayName": "Florin",
  "description": "Portable database workbench for VS Code: browse, query, and sync your connections + saved queries to a Git repo you own. Passwords stay in the OS keychain.",
  "version": "0.4.0",
  "publisher": "asutoshpanda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/75asu/florin.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "florin",
          "title": "Florin",
          "icon": "media/florin.svg"
        }
      ]
    },
    "views": {
      "florin": [
        {
          "id": "florin.connections",
          "name": "Connections",
          "icon": "media/florin.svg"
        },
        {
          "id": "florin.queries",
          "name": "Saved Queries",
          "icon": "media/florin.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "florin.connections",
        "contents": "No database connections yet.\n[Add Connection from URL](command:florin.addConnectionFromUrl)"
      },
      {
        "view": "florin.queries",
        "contents": "No saved queries yet.\nRun a query in the console and press Save to file it here.\n[Configure Vault (Sync)](command:florin.configureVault)"
      }
    ],
    "commands": [
      {
        "command": "florin.addConnectionFromUrl",
        "title": "Add Connection from URL",
        "category": "Florin",
        "icon": "$(add)"
      },
      {
        "command": "florin.refresh",
        "title": "Refresh",
        "category": "Florin",
        "icon": "$(refresh)"
      },
      {
        "command": "florin.previewTable",
        "title": "Preview Rows",
        "category": "Florin",
        "icon": "$(eye)"
      },
      {
        "command": "florin.renameConnection",
        "title": "Rename Connection",
        "category": "Florin",
        "icon": "$(edit)"
      },
      {
        "command": "florin.deleteConnection",
        "title": "Remove Connection",
        "category": "Florin",
        "icon": "$(trash)"
      },
      {
        "command": "florin.newQuery",
        "title": "New Query",
        "category": "Florin",
        "icon": "$(notebook)"
      },
      {
        "command": "florin.openSavedQuery",
        "title": "Open Saved Query",
        "category": "Florin",
        "icon": "$(bookmark)"
      },
      {
        "command": "florin.configureVault",
        "title": "Configure Vault (Sync)",
        "category": "Florin",
        "icon": "$(cloud)"
      },
      {
        "command": "florin.refreshQueries",
        "title": "Refresh Saved Queries",
        "category": "Florin",
        "icon": "$(refresh)"
      },
      {
        "command": "florin.openQueryItem",
        "title": "Open Query",
        "category": "Florin"
      },
      {
        "command": "florin.renameQueryItem",
        "title": "Rename Query",
        "category": "Florin",
        "icon": "$(edit)"
      },
      {
        "command": "florin.deleteQueryItem",
        "title": "Delete Query",
        "category": "Florin",
        "icon": "$(trash)"
      }
    ],
    "configuration": {
      "title": "Florin",
      "properties": {
        "florin.vault.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to a Git repo folder Florin syncs connections and queries to. Leave empty to keep everything on this machine only."
        },
        "florin.vault.subdir": {
          "type": "string",
          "default": "florin",
          "description": "Subdirectory inside the vault repo where Florin writes its files."
        },
        "florin.vault.autoSync": {
          "type": "boolean",
          "default": true,
          "description": "Pull the vault on window focus and commit+push automatically when connections or queries change."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "florin.addConnectionFromUrl",
          "when": "view == florin.connections",
          "group": "navigation@1"
        },
        {
          "command": "florin.openSavedQuery",
          "when": "view == florin.connections",
          "group": "navigation@2"
        },
        {
          "command": "florin.refresh",
          "when": "view == florin.connections",
          "group": "navigation@3"
        },
        {
          "command": "florin.configureVault",
          "when": "view == florin.connections",
          "group": "1_vault@1"
        },
        {
          "command": "florin.openSavedQuery",
          "when": "view == florin.queries",
          "group": "navigation@1"
        },
        {
          "command": "florin.refreshQueries",
          "when": "view == florin.queries",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "florin.previewTable",
          "when": "view == florin.connections && viewItem == florin.table",
          "group": "inline"
        },
        {
          "command": "florin.previewTable",
          "when": "view == florin.connections && viewItem == florin.table",
          "group": "0_preview@1"
        },
        {
          "command": "florin.newQuery",
          "when": "view == florin.connections && viewItem == florin.table",
          "group": "0_preview@2"
        },
        {
          "command": "florin.newQuery",
          "when": "view == florin.connections && (viewItem == florin.connection || viewItem == florin.database)",
          "group": "inline@1"
        },
        {
          "command": "florin.renameConnection",
          "when": "view == florin.connections && viewItem == florin.connection",
          "group": "inline@2"
        },
        {
          "command": "florin.newQuery",
          "when": "view == florin.connections && (viewItem == florin.connection || viewItem == florin.database)",
          "group": "1_query@1"
        },
        {
          "command": "florin.renameConnection",
          "when": "view == florin.connections && viewItem == florin.connection",
          "group": "1_manage@1"
        },
        {
          "command": "florin.deleteConnection",
          "when": "view == florin.connections && viewItem == florin.connection",
          "group": "1_manage@2"
        },
        {
          "command": "florin.renameQueryItem",
          "when": "view == florin.queries && viewItem == florin.queryItem",
          "group": "inline@1"
        },
        {
          "command": "florin.deleteQueryItem",
          "when": "view == florin.queries && viewItem == florin.queryItem",
          "group": "inline@2"
        },
        {
          "command": "florin.renameQueryItem",
          "when": "view == florin.queries && viewItem == florin.queryItem",
          "group": "1_edit@1"
        },
        {
          "command": "florin.deleteQueryItem",
          "when": "view == florin.queries && viewItem == florin.queryItem",
          "group": "1_edit@2"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "package": "vsce package -o florin.vsix",
    "install:local": "npm run package && code --install-extension florin.vsix --force",
    "vscode:prepublish": "npm run check-types && node esbuild.js --production",
    "prepare": "husky"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.4.0",
    "@lezer/highlight": "^1.2.3",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.1.0",
    "codemirror": "^6.0.2",
    "esbuild": "^0.23.0",
    "husky": "^9.1.0",
    "sql-formatter": "^15.8.2",
    "typescript": "^5.5.0"
  },
  "allowScripts": {
    "esbuild@0.23.1": true
  }
}
